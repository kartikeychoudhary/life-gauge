# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=life_gauge
DB_USER=root
DB_PASSWORD=secret

# JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRY=24h

# Encryption (used for LLM API key storage) — must be 32 chars for AES-256
ENCRYPTION_KEY=your-32-char-encryption-key-here!!

# Backend
API_PORT=3000
# NODE_ENV=development

# Frontend
NG_PORT=4200

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
